  "keyFeatures": [
    "Dynamic and static challenge types with multiple attachment modes",
    "Real-time scoreboard with dynamic scoring algorithm",
    "Docker and Kubernetes container orchestration",
    "Team management with divisions and participation controls",
    "Real-time monitoring with SignalR for events and submissions",
    "Traffic capture and TCP over WebSocket proxy",
    "Multi-language support with internationalization",
    "Writeup collection and review system",
    "SMTP verification and Cloudflare Turnstile protection",
    "Redis caching and PostgreSQL storage",
    "Object storage support (MinIO, S3)",
    "OpenTelemetry metrics and distributed tracing"
  ],
  "publicApiSurface": [
    "GET /api/game/recent - Get recent games",
    "GET /api/game/{id} - Get game details",
    "POST /api/game/{id}/submit - Submit a flag",
    "GET /api/game/{id}/challenges - Get game challenges",
    "GET /api/game/{id}/scoreboard - Get scoreboard",
    "POST /api/team/create - Create a team",
    "GET /api/team/{id} - Get team information",
    "POST /api/account/register - Register new account",
    "POST /api/account/login - User login",
    "GET /api/admin/games - List all games (admin)",
    "POST /api/admin/games - Create new game (admin)",
    "POST /api/admin/challenges - Create challenge (admin)"
  ]
